{
  "name": "float3-wasm-bundle",
  "version": "1.0.0",
  "description": "wasm",
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "serve_release": "bun run webpack-dev-server --config webpack.config.mjs --mode production",
    "serve_dev": "bun run webpack-dev-server --config webpack.config.mjs --mode development",
    "check": "bun run tsc --noEmit --incremental false && bun run eslint src",
    "format": "bun run prettier src --write && bun run eslint src --fix",
    "watch": "bun run tsc && bun scripts/watch.mts",
    "watch:ts": "bun run tsc --watch --preserveWatchOutput",
    "watch:webpack": "bun run webpack --config webpack.config.mjs --mode development --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/float3/float3.github.io.git",
    "directory": "wasm/bundle"
  },
  "keywords": [
    "webassembly",
    "wasm",
    "rust",
    "webpack"
  ],
  "author": "hill <hill@hilll.dev>",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/float3/float3.github.io/issues"
  },
  "homepage": "https://github.com/float3/float3.github.io#readme",
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "@types/webmidi": "^3.0.1",
    "abcjs": "^6.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "terser-webpack-plugin": "^5.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  },
  "packageManager": "bun@1.3.13",
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "uuid": "^14.0.0"
  }
}
