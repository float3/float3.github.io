{
  "name": "float3-wasm-bundle",
  "version": "1.0.0",
  "description": "wasm",
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "serve_release": "node node_modules/webpack-dev-server/bin/webpack-dev-server.js --config webpack.config.mjs --mode production",
    "serve_dev": "node node_modules/webpack-dev-server/bin/webpack-dev-server.js --config webpack.config.mjs --mode development",
    "check": "node node_modules/typescript/bin/tsc --noEmit --incremental false && node node_modules/eslint/bin/eslint.js src",
    "format": "node node_modules/prettier/bin/prettier.cjs src --write && node node_modules/eslint/bin/eslint.js src --fix",
    "watch": "node node_modules/typescript/bin/tsc && node node_modules/npm-run-all/bin/run-p/index.js watch:ts watch:webpack",
    "watch:ts": "node node_modules/typescript/bin/tsc --watch --preserveWatchOutput",
    "watch:webpack": "node node_modules/webpack/bin/webpack.js --config webpack.config.mjs --mode development --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/float3/float3.github.io.git",
    "directory": "wasm/bundle"
  },
  "keywords": [
    "webassembly",
    "wasm",
    "rust",
    "webpack"
  ],
  "author": "hill <hill@hilll.dev>",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/float3/float3.github.io/issues"
  },
  "homepage": "https://github.com/float3/float3.github.io#readme",
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "@types/webmidi": "^2.1.0",
    "abcjs": "^6.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jiti": "^2.4.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "terser-webpack-plugin": "^5.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "packageManager": "bun@1.3.13",
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "uuid": "^14.0.0"
  }
}
